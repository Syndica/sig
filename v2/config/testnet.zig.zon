.{
    .sandboxing_mode = .sandboxed,

    .cluster = .testnet,
    .leader_schedule_file = "schedule.txt",
    .gossip = .{
        .port = 8001,
    },
    .shred_network = .{
        .recv_port = 8002,
    },
    .telemetry = .{
        .port = 12345,
    },
    .snapshot = .{
        .folder = "./validator",
    },
    .accounts_db = .{
        .file = "./validator/accounts.db",
        .memory = .{ .gb = 8 }, // mainnet needs 64, testnet only 8 or so
    },
}
