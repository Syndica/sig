# The commits currently used in CI for sig's conformance with agave.

# Repo: https://github.com/firedancer-io/solana-conformance.git
SOLANA_CONFORMANCE_COMMIT="0058c4b94b007ba25b13deeec46b6322fa6f051f"

# Repo: https://github.com/firedancer-io/test-vectors.git
# NOTE: This is the last commit before re-keying the `discard_unexpected_data_complete_shreds'
# which is not currenty re-keyed in agave-v4.0.0-beta.6. Once we reach conformance with agave-v4.0.0-beta.6, 
# we can upgrade the solfuzz and test vectors commits together.
TEST_VECTORS_COMMIT="2e0d3eeb2fc6d2dbaaca97d9ca72fce28d2611a8"

# Tag:  agave-v4.0.0-beta.6
# Repo: https://github.com/firedancer-io/solfuzz-agave.git
SOLFUZZ_AGAVE_COMMIT="ff66b6b6a1a5f758bcc6523b949419c0b11c4242"

# Tag:  5.5.0-beta.0
# Repo: https://github.com/firedancer-io/protosol.git
# NOTE: Nix needs a fixed git commit here because pure flake evaluation cannot resolve an
# unlocked protosol tag to its commit SHA on the fly. When updating
# SOLFUZZ_AGAVE_COMMIT, read the protosol version from solfuzz-agave's Cargo.toml or
# Cargo.lock, resolve the matching protosol tag to a commit SHA (for example with
# `git ls-remote https://github.com/firedancer-io/protosol.git refs/tags/v<version>`),
# and update this pin to that SHA.
SOLFUZZ_AGAVE_PROTOSOL_COMMIT="5e8c685624d7598bd1d804059b894e966dbf80d5"
